{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "types": ["node"],

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true
  },

  "include": ["src/**/*", "playground/promise-test.ts", "playground/promise-demo.ts"],
  "exclude": ["node_modules"]
}